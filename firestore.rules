rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: plans
    // Fields:
    //   - name: string (required)
    //   - price: string (required)
    //   - period: string
    //   - features: list (required)
    //   - popular: bool
    //   - order: int
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (admin, user)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ghoshsima874@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPlan(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.features is list && data.features.size() > 0 && data.features.size() < 20 &&
             data.category in ['minecraft', 'vps'] &&
             (!('subCategory' in data) || data.subCategory in ['premium', 'budget']) &&
             data.order is int;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /plans/{planId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidPlan(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
        (request.resource.data.role == 'user' || (request.auth.token.email == "ghoshsima874@gmail.com" && request.resource.data.role == 'admin'));
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }
  }
}
